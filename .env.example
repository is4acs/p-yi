# ============================================================================
# PÉYI — Variables d'environnement (template)
# ----------------------------------------------------------------------------
# Copie ce fichier en .env.local (local dev) ou .env (runtime), puis remplace
# les valeurs placeholder par tes vraies clés.
# Ne JAMAIS commit .env ou .env.local (déjà dans .gitignore).
# ============================================================================

# ----- DATABASE (Supabase Postgres via Prisma) -------------------------------
# Fournies par Supabase → Connect → ORMs → Prisma
# 6543 = pooler transaction mode (app runtime), 5432 = direct (migrations)
DATABASE_URL="postgresql://postgres.[ref]:[password]@[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@[region].pooler.supabase.com:5432/postgres"

# ----- SUPABASE (Auth + Storage + Realtime) ----------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ----- MEILISEARCH (moteur de recherche) -------------------------------------
MEILISEARCH_HOST="https://ms-xxxx.meilisearch.io"
MEILISEARCH_API_KEY="xxx"
MEILISEARCH_MASTER_KEY="xxx"

# ----- CLOUDFLARE R2 (stockage images) ---------------------------------------
R2_ACCOUNT_ID="xxx"
R2_ACCESS_KEY_ID="xxx"
R2_SECRET_ACCESS_KEY="xxx"
R2_BUCKET_NAME="peyi-images"
R2_PUBLIC_URL="https://cdn.peyi.com"

# ----- TWILIO (SMS OTP — optionnel si Supabase phone auth suffit) -----------
TWILIO_ACCOUNT_SID="xxx"
TWILIO_AUTH_TOKEN="xxx"
TWILIO_PHONE_NUMBER="+33..."

# ----- RESEND (emails transactionnels) ---------------------------------------
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="hello@peyi.com"

# ----- ONESIGNAL (push web) --------------------------------------------------
NEXT_PUBLIC_ONESIGNAL_APP_ID="xxx"
ONESIGNAL_REST_API_KEY="xxx"

# ----- UPSTASH REDIS (rate limit + cache) -----------------------------------
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxx"

# ----- AFFILIATION -----------------------------------------------------------
AMAZON_PARTNER_TAG="peyi-21"
AWIN_PUBLISHER_ID="xxx"

# ----- ANALYTICS -------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="peyi.com"

# ----- CRON (Vercel) ---------------------------------------------------------
CRON_SECRET="un-long-token-random-a-generer"

# ----- SITE ------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://peyi.com"
NEXT_PUBLIC_SITE_NAME="Péyi"

# ----- ENV -------------------------------------------------------------------
NODE_ENV="development"

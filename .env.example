# ============================================================================
# PÉYI — Variables d'environnement
# ----------------------------------------------------------------------------
# Copie ce fichier en .env.local (dev) ou .env (runtime), remplace les
# placeholders par tes vraies clés. Ne JAMAIS commit .env ou .env.local
# (déjà dans .gitignore).
#
# Validation : src/lib/env.ts valide ces variables via zod au démarrage.
# Si une variable manque ou est invalide, l'app fail-fast avec un message
# listant tous les problèmes d'un coup.
# ============================================================================


# ============================================================================
#                            REQUIS (app ne boot pas sans)
# ============================================================================

# ----- Database (Supabase Postgres via Prisma) ------------------------------
# Dashboard Supabase → Connect → ORMs → Prisma
# 6543 = pooler transaction mode (app runtime)
# 5432 = direct (migrations Prisma)
DATABASE_URL="postgresql://postgres.[ref]:[password]@[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@[region].pooler.supabase.com:5432/postgres"

# ----- Supabase (Auth + Storage) --------------------------------------------
# Dashboard Supabase → Settings → API
# ANON = côté client (expose dans le bundle navigateur)
# SERVICE_ROLE = côté serveur uniquement (admin API, suppression utilisateur)
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ----- Site ------------------------------------------------------------------
# URL canonique de l'app. Sert pour les liens absolus dans les metadata
# (OG images, sitemap, canonical), les redirects OAuth, etc. Sans slash final.
NEXT_PUBLIC_SITE_URL="https://peyi.com"


# ============================================================================
#                  REQUIS EN PRODUCTION (boot bloqué sans)
# ============================================================================

# ----- Upstash Redis (rate limiting) ----------------------------------------
# Dashboard Upstash → Console → Details (REST URL + Token)
# OBLIGATOIRE en prod : src/lib/env.ts refuse de booter si NODE_ENV=production
# et qu'une des deux variables manque (sinon brute-force auth, spam, DoS export).
# En dev/test : optionnel — `rate-limit.ts` tombe en no-op et logue un warning.
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxx"

# Échappatoire UNIQUEMENT pour situations exceptionnelles (build CI sans
# accès aux secrets prod, environnement de démo isolé). NE JAMAIS poser
# en production réelle — désactive complètement le rate limiting.
# ALLOW_NO_RATE_LIMIT="1"


# ============================================================================
#                                   OPTIONNEL
# ============================================================================

# ----- Logger ---------------------------------------------------------------
# Seuil des logs émis (debug/info/warn/error). Par défaut : info en prod,
# debug en dev. Mettre "debug" en prod pour diagnostiquer, mais prod = bruit.
# LOG_LEVEL="info"

# ----- Next standard --------------------------------------------------------
# Next le pose automatiquement. Tu ne devrais pas avoir à le fixer.
# NODE_ENV="development"


# ============================================================================
#                          ROADMAP (pas encore câblé)
# ============================================================================
# Ces variables ne sont PAS utilisées par l'app actuelle. Elles sont
# listées ici pour documenter les intégrations prévues et éviter de
# reconfigurer le même bloc à chaque session. Décommente au moment
# d'implémenter l'intégration correspondante.

# ----- Meilisearch (moteur de recherche avancée) ----------------------------
# MEILISEARCH_HOST="https://ms-xxxx.meilisearch.io"
# MEILISEARCH_API_KEY="xxx"
# MEILISEARCH_MASTER_KEY="xxx"

# ----- Cloudflare R2 (stockage images — alternative à Supabase Storage) -----
# R2_ACCOUNT_ID="xxx"
# R2_ACCESS_KEY_ID="xxx"
# R2_SECRET_ACCESS_KEY="xxx"
# R2_BUCKET_NAME="peyi-images"
# R2_PUBLIC_URL="https://cdn.peyi.com"

# ----- Resend (emails transactionnels) --------------------------------------
# RESEND_API_KEY="re_xxx"
# RESEND_FROM_EMAIL="hello@peyi.com"

# ----- OneSignal (push web) -------------------------------------------------
# NEXT_PUBLIC_ONESIGNAL_APP_ID="xxx"
# ONESIGNAL_REST_API_KEY="xxx"

# ----- Affiliation ----------------------------------------------------------
# AMAZON_PARTNER_TAG="peyi-21"
# AWIN_PUBLISHER_ID="xxx"

# ----- Analytics (alternative à WebVitals → /api/metrics) -------------------
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="peyi.com"

# ----- Cron Vercel (jobs de maintenance) ------------------------------------
# CRON_SECRET="un-token-random-long-a-generer"
